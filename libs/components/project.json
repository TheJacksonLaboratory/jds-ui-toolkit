{
  "name": "components",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/components/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "compile-css": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node compile-styles.js",
        "cwd": "libs/components"
      }
    },
    "copy-styles": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node copy-styles.js",
        "cwd": "libs/components"
      }
    },
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/libs/components"],
      "options": {
        "project": "libs/components/ng-package.json"
      },
      "dependsOn": [
        {
          "target": "build",
          "projects": ["api-clients"]
        },
        {
          "target": "compile-css",
          "projects": "self"
        },
        {
          "target": "copy-styles",
          "projects": "self"
        }
      ],
      "configurations": {
        "production": {
          "tsConfig": "libs/components/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/components/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/components/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
