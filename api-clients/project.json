{
  "name": "api-clients",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "api-clients/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "api-clients/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "api-clients/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "api-clients/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "api-clients/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "nx-release-publish": {
      "options":{
        "packageRoot": "dist/api-clients"
      }
    }
  }
}
